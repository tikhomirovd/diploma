OPENROUTER_API_KEY=your_openrouter_key_here

# Default model fallback (used if per-role vars are not set)
MODEL=openai/gpt-4o

# Per-role model selection (all via OpenRouter)
# Emotion agents: the 5 Ekman-emotion nodes in ERC and ERG graphs
EMOTION_AGENT_MODEL=openai/gpt-4o-mini

# Aggregate agent: synthesises emotion-agent outputs into a final answer
AGGREGATE_MODEL=openai/gpt-4o

# Assessor model: LLM-as-judge for ERG quality scoring (--judge flag)
ASSESSOR_MODEL=openai/gpt-4o
